# App
NEXT_PUBLIC_APP_NAME="FitSupplement Store"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fitsupplement_store?schema=public"

# Auth placeholders
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_SESSION_COOKIE_NAME="fitsupplement.session"
OTP_PROVIDER="disabled"

# Payments placeholders
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
CASHFREE_APP_ID=""
CASHFREE_SECRET_KEY=""

# Shipping placeholders
SHIPROCKET_EMAIL=""
SHIPROCKET_PASSWORD=""
DELHIVERY_API_TOKEN=""

# Storage placeholders
STORAGE_PROVIDER="local"
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# Search placeholders
SEARCH_PROVIDER="basic"
ALGOLIA_APP_ID=""
ALGOLIA_ADMIN_API_KEY=""
