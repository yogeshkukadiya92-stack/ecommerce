# App
NEXT_PUBLIC_APP_NAME="FitSupplement Store"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NODE_ENV="development"
LOG_LEVEL="info"
NEXT_PUBLIC_SHOW_DEMO_DATA="false"

# Database
DATABASE_URL="mongodb://localhost:27017/fitsupplement_store"

# Auth
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_SESSION_COOKIE_NAME="fitsupplement.session"
OTP_PROVIDER="disabled"
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_NAME="Store Owner"
ADMIN_SESSION_TIMEOUT_MINUTES="30"
RATE_LIMIT_ENABLED="false"

# Payments configuration
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
RAZORPAY_TEST_MODE="true"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
CASHFREE_APP_ID=""
CASHFREE_SECRET_KEY=""

# Shipping configuration
SHIPROCKET_API_BASE="https://apiv2.shiprocket.in/v1/external"
SHIPROCKET_EMAIL=""
SHIPROCKET_PASSWORD=""
SHIPROCKET_PICKUP_LOCATION=""
SHIPROCKET_DEFAULT_WEIGHT_KG="0.5"
SHIPROCKET_CHANNEL_ID=""
SHIPROCKET_WEBHOOK_SECRET=""
DELHIVERY_API_TOKEN=""

# Storage configuration
STORAGE_PROVIDER="local"
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# Search configuration
SEARCH_PROVIDER="basic"
ALGOLIA_APP_ID=""
ALGOLIA_ADMIN_API_KEY=""

# Communication configuration
EMAIL_PROVIDER="disabled"
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""
SMS_PROVIDER="disabled"
SMS_API_KEY=""
WHATSAPP_PROVIDER="disabled"
WHATSAPP_ACCESS_TOKEN=""

# Monitoring and backup configuration
SENTRY_DSN=""
ANALYTICS_PROVIDER="disabled"
GA_MEASUREMENT_ID=""
BACKUP_PROVIDER="disabled"
BACKUP_BUCKET=""
